# ─────────────────────────────────────────────
#  Peblo Notes — Environment Variables Example
#  Copy this file to .env and fill in values.
#  NEVER commit your real .env to Git.
# ─────────────────────────────────────────────

# Server (must match frontend/vite.config.js proxy target)
PORT=5001
NODE_ENV=development

# Database (SQLite file path)
DATABASE_URL=./data/peblo.db

# JWT Secret — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# JWT expiration (e.g., 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# AI Provider — Google Gemini
# Get your key at: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here

# Gemini model name
GEMINI_MODEL=gemini-2.0-flash

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional — required for "Continue with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
